OLLAMA_HOST=http://localhost
OLLAMA_PORT=11434
API_KEY=

# Chat/LLM provider. Use "openai-compatible" for /v1/chat/completions or "ollama" for the existing Ollama generation path.
CHAT_PROVIDER=openai-compatible
CHAT_MODEL=
OPENAI_COMPATIBLE_BASE_URL=http://localhost:11434/v1
OPENAI_COMPATIBLE_API_KEY=

FILES_FOLDER=/var/woodstock/files
SERVER_PORT=
DB_HOST=
DB_USER=
DB_PASSWORD=
DB_PORT=
QDRANT_COLLECTION=
QDRANT_SERVER=
MAIL_SECRET=

# Docling ingestion. DUCLING_BOOTSTRAP=0 skips startup installation/model checks.
DUCLING_BOOTSTRAP=1
DUCLING_BIN=.local-bin/docling
DUCLING_VENV=.venv
DUCLING_ARTIFACTS_PATH=.docling-models
DUCLING_NUM_THREADS=4
DUCLING_DEVICE=cpu
DUCLING_OCR=0
RAG_IMAGE_FOLDER=files/rag-images
